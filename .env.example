# km-aggregator — environment configuration
# Copy to .env and fill in values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://km:km@localhost:5432/km

# ── Inference (Ollama — self-hosted, no paid API required) ────────────────────
# Point to your Ollama instance. Default: localhost for local dev.
# Production: set to your inference stack host.
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
SYNTHESIS_MODEL=llama3.3:70b

# ── Notifications ─────────────────────────────────────────────────────────────
# Mattermost incoming webhook URL.
# Create at: Team Settings > Integrations > Incoming Webhooks
MATTERMOST_WEBHOOK_URL=

# ── prom-memory integration (optional) ────────────────────────────────────────
# Leave empty to disable. Set PROM_MEMORY_ENABLED=true to activate writes.
PROM_MEMORY_URL=
PROM_MEMORY_ENABLED=false

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
